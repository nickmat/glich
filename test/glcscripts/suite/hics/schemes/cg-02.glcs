// hics/schemes/cg-02.glcs - Test Proposed Chinese Calendar with Gregorian Year
// scheme shorthand ranges

lexicon FS {
    name "First and Second";
    fieldname lmonth;
    lang en;
    pseudo     FirstSecond,     FS;
    tokens {
        0,  "First", "F";
        1,  "Second", "S";
    };
};

grammar C {
    fields year month lmonth day cycle cyear;
    rank year month lmonth day;
    calculated clmonth stem branch;
    // year month lmonth day cycle cyear clmonth stem branch

    lexicons FS;
    alias pseudo { dd day; mm month; lm lmonth; yy year; cc cycle; };
    alias unit { d day; m month; lm lmonth; y cyear; c cycle; };

    function calculate { // calculate
        stem = (cyear - 1) mod 10 + 1;
        branch = (cyear - 1) mod 12 + 1;
        clmonth = @if(lmonth=0, null, 1);
        result = this;
    };

    function fixed { // format cymld
        if stem <> null and branch <> null {
            cyear = ((stem - branch) mod 12) * 5 + stem;
        };
        if cycle <> null and cyear <> null {
            year = (cycle - 1) * 60 + cyear;
        };
        clmonth = @if(lmonth=0, null, 1);
        stem = (cyear - 1) mod 10 + 1;
        branch = (cyear - 1) mod 12 + 1;
        result = this;
    };

    // Note, format used in "Calendrical Calculations"
    format ymld {
        inout "{year}| {month}| {lmonth:FS:a:l}| {day}";
    };
    preferred ymld;
};

scheme CG {
  name "Chinese with Gregorian Year";
  base chinese year:2637;
  grammar C;
};


write nl;
write @fmt:object.CG:u[.shorthand], @fmt:object.CG:r[.shorthand], @fmt:object.CG:cymld[.shorthand] nl;
write @date.CG( "2025 6 f 15" ), @text.CG( 2460866 ) nl;
write @date.CG( "2025 6 f" ), @text.CG( 2460852..2460881 ) nl;
write @date.CG( "2025 6 s" ), @text.CG( 2460882..2460910 ) nl;
write @date.CG( "2025 7 f" ), @text.CG( 2460911..2460940 ) nl;
write @date.CG( "2025 6" ), @text.CG( 2460852..2460910 ) nl;
write @date.CG( "2025 7" ), @text.CG( 2460911..2460940 ) nl;
write @date.CG( "2025" ), @text.CG( 2460705..2461088 ) nl;


/*[OUTPUT]

false, true, null
2460866, 2025 6 f 15
2460852..2460881, 2025 6 f
2460882..2460910, 2025 6 s
2460911..2460940, 2025 7
2460852..2460910, 2025 6
2460911..2460940, 2025 7
2460705..2461088, 2025

[OUTPUT]*/
