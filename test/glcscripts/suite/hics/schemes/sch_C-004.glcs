// hics/schemes/sch_C-004.glcs - Test Chinese Calendar scheme.
// Test format 'cymld' with additional fields cycle and segyear.
// This is the format used in "Calendrical Calculations" by Reingold and Dershowitz.  

lexicon FS {
    name "First and Second";
    fieldname lmonth;
    lang en;
    pseudo     FirstSecond,     FS;
    tokens {
        1,  "First", "F";
        2,  "Second", "S";
    };
};

grammar C {
    fields year month lmonth day cycle segyear;
    rank cycle segyear month lmonth day;

    lexicons FS;
    alias pseudo { dd day; mm month; lm lmonth; yy year; cc cycle; ss segyear; };
    alias unit { d day; m month; lm lmonth; y year; c cycle; sy segyear; };

    // Note, format used in "Calendrical Calculations"
    format cymld "{cycle}| {segyear}| {month}| {lmonth:FS:a:l}| {day}";
    preferred cymld;
};

scheme C {
  name "Chinese Test";
  base chinese additional;
  grammar C;
};

write nl;
write "Shorthand range: " + @fmt:object.C:cymld[.shorthand] nl;
write @date.C( "78 42 6 f 15" ), @text.C( 2460866 ) nl;
write @date.C( "78 42 6 f" ), @text.C( 2460852..2460881 ) nl;
write @date.C( "78 42 6 s" ), @text.C( 2460882..2460910 ) nl;
write @date.C( "78 42 7 f" ), @text.C( 2460911..2460940 ) nl;
write @date.C( "78 42 6" ), @text.C( 2460852..2460910 ) nl;
write @date.C( "78 42 7" ), @text.C( 2460911..2460940 ) nl;
write @date.C( "78 42" ), @text.C( 2460705..2461088 ) nl;
write @date.C( "78" ), @text.C( 2445733..2467644 ) nl;


/*[OUTPUT]

Shorthand range: true
2460866, 78 42 6 f 15
2460852..2460881, 78 42 6 f
2460882..2460910, 78 42 6 s
2460911..2460940, 78 42 7
2460852..2460910, 78 42 6
2460911..2460940, 78 42 7
2460705..2461088, 78 42
2445733..2467644, 78

[OUTPUT]*/

