// hics/schemes/c-04.glcs - Test Proposed Chinese Calendar scheme shorthand ranges

lexicon FS {
    name "First and Second";
    fieldname lmonth;
    lang en;
    pseudo     FirstSecond,     FS;
    tokens {
        0,  "First", "F";
        1,  "Second", "S";
    };
};

grammar C {
    fields year month lmonth day cycle cyear;
    rank year month lmonth day;
    calculated clmonth stem branch;
    // year month lmonth day cycle cyear clmonth stem branch

    lexicons FS;
    alias pseudo { dd day; mm month; lm lmonth; yy year; cc cycle; };
    alias unit { d day; m month; lm lmonth; y cyear; c cycle; };

    function calculate { // calculate
        stem = (cyear - 1) mod 10 + 1;
        branch = (cyear - 1) mod 12 + 1;
        clmonth = @if(lmonth=0, null, 1);
        result = this;
    };

    function fixed { // format cymld
        if stem <> null and branch <> null {
            cyear = ((stem - branch) mod 12) * 5 + stem;
        };
        if cycle <> null and cyear <> null {
            year = (cycle - 1) * 60 + cyear;
        };
        clmonth = @if(lmonth=0, null, 1);
        stem = (cyear - 1) mod 10 + 1;
        branch = (cyear - 1) mod 12 + 1;
        result = this;
    };

    function first.field {
        result = @if( field = "cyear", 1f, ?);
    };
    function last.field {
        result = @if( field = "cyear", 60f, ?);
    };

    // Note, format used in "Calendrical Calculations"
    format cymld "{year}| {month}| {lmonth:FS:a:l}| {day}";
    preferred cymld;
};

scheme C {
  name "Chinese";
  base chinese;
  grammar C;
};


write nl;
write @fmt:object.C:u[.shorthand], @fmt:object.C:r[.shorthand], @fmt:object.C:cymld[.shorthand] nl;
write @date.C( "4662 6 f 15" ), @text.C( 2460866 ) nl;
write @date.C( "4662 6 f" ), @text.C( 2460852..2460881 ) nl;
write @date.C( "4662 6 s" ), @text.C( 2460882..2460910 ) nl;
write @date.C( "4662 7 f" ), @text.C( 2460911..2460940 ) nl;
write @date.C( "4662 6" ), @text.C( 2460852..2460910 ) nl;
write @date.C( "4662 7" ), @text.C( 2460911..2460940 ) nl;
write @date.C( "4662" ), @text.C( 2460705..2461088 ) nl;

/*[OUTPUT]

false, true, true
2460866, 4662 6 f 15
2460852..2460881, 4662 6 f
2460882..2460910, 4662 6 s
2460911..2460940, 4662 7
2460852..2460910, 4662 6
2460911..2460940, 4662 7
2460705..2461088, 4662

[OUTPUT]*/
