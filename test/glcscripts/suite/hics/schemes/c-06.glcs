// hics/schemes/c-06.glcs - Test Chinese Calendar scheme.

grammar C {
    fields year month lmonth day cycle cyear;
    rank year month lmonth day;
    optional wday;
};

scheme C {
    base chinese;
    grammar C;
};

write nl;
write @text.C:a( 2460494 ), @date.C:a( "4661 5 0 27 78 41 2" ) nl;
write @text.C:r( 2460494 ), @date.C:r( "4661 5 0 27" ) nl;
write @text.C:u( 2460494 ), @date.C:u( "4661year 5month 0lmonth 27day 78cycle 41cyear" ) nl;

write nl;
write @scheme.C( 758326 ), @date( {s:C 1, 1, 0, 1} ) nl;
write @text.C( 2460494 ), @scheme.C( 2460494 ) nl;
write @date.C( "4661 5 0 27" ),  @scheme.C( "4661 5 0 27" ) nl;
write @text( {s:C 4661, 5, 0, 27} ), @date( {s:C 4661, 5, 0, 27} ) nl;
write nl;
write @date.C( "4662 6 0 20" ), @text.C( 2460871 ) nl;
write @date.C( "4662 6 0" ), @text.C( 2460852..2460881 ) nl;
write @date.C( "4662 6" ), @text.C( 2460852..2460910 ) nl;
write @date.C( "4662" ), @text.C( 2460705..2461088 ) nl;


/*[OUTPUT]

4661 5 0 27 78 41 2, 2460494
4661 5 0 27, 2460494
4661year 5month 0lmonth 27day 78cycle 41cyear, 2460494

{s:C 1, 1, 0, 1, 1, 1, 3}, 758326
4661 5 0 27, {s:C 4661, 5, 0, 27, 78, 41, 2}
2460494, {s:C 4661, 5, 0, 27, null, null, 2}
4661 5 0 27, 2460494

2460871, 4662 6 0 20
2460852..2460881, 4662 6 0
2460852..2460910, 4662 6
2460705..2461088, 4662

[OUTPUT]*/
