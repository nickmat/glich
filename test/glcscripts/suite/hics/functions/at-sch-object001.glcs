// at-sch-object001.glcs  Test @sch:object function

scheme G { base gregorian; };

let s = @sch:object.G;

write nl;
write s[.code], s[.basename], s[.default:in], s[.default:out], s[.visible] nl;
write s[.fieldnames] nl;
write s[.formats] nl;

/*[OUTPUT]

G, gregorian, r, r, true
{: "year", "month", "day"}
{: "a", "r", "u"}

[OUTPUT]*/
