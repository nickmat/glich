// at-leapyear001.glcs  Test scheme functions


write nl;
write @leapyear.g(1900) nl;
write @leapyear.g(2024) nl;
write @leapyear.g(2025) nl;
write @leapyear.j(2024) nl;
write @leapyear.j(2025) nl;
write @leapyear(2025) nl;
write @leapyear.X(2025) nl;
write @leapyear.g nl;
write @leapyear.rd(2025) nl;


