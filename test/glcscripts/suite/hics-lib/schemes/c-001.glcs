// hics-lib/schemes/c-001.glcs - Test Hics library Chinese Calendar scheme.
// Test Year count formats.
/*[SKIP]*/
let d1 = 2460866;   // 4662y 6m 0lm 15d 78c 42cy 2s 6b
let d2 = 2460896;   // 4662y 6m 1lm 15d 78c 42cy 1cm 2s 6b
let d3 = 2460925;   // 4662y 7m 0lm 15d 78c 42cy 2s 6b
let m1 = 2460852..2460881; // 4662y 6m 0lm 1d 78c 42cy 2s 6b..4662y 6m 0lm 30d 78c 42cy 2s 6b
let m2 = 2460882..2460910; // 4662y 6m 1lm 1d 78c 42cy 1cm 2s 6b..4662y 6m 1lm 29d 78c 42cy 1cm 2s 6b
let m3 = 2460911..2460940; // 4662y 7m 0lm 1d 78c 42cy 2s 6b..4662y 7m 0lm 30d 78c 42cy 2s 6b
let md = 2460852..2460910; // 4662y 6m 0lm 1d 78c 42cy 2s 6b..4662y 6m 1lm 29d 78c 42cy 1cm 2s 6b
let y = 2460705..2461088;  // 4662y 1m 0lm 1d 78c 42cy 2s 6b..4662y 12m 0lm 29d 78c 42cy 2s 6b


let sig = "c:ymld";
write nl; // default ymld format
write @text.(sig)( d1 ), @text.(sig)( d2 ), @text.(sig)( d3 ) nl;
write @text.(sig)( m1 ), @text.(sig)( m2 ), @text.(sig)( m3 ) nl;
write @text.(sig)( md ) nl;
write @text.(sig)( y ) nl;

write @date.(sig)( {s:c 4662, 6, 0, 15} ), @date.(sig)( {s:c 4662, 6, 1, 15} ), @date.(sig)( {s:c 4662, 7, 0, 15} ) nl;
write @date.(sig)("4662 6 f 15"), @date.(sig)("4662 6 s 15"), @date.(sig)("4662 7 f 15") nl;
write @date.(sig)("4662 6 f"), @date.(sig)("4662 6 s"), @date.(sig)("4662 7 f") nl;
write @date.(sig)("4662 6"), @date.(sig)("4662 7") nl;
write @date.(sig)("4662") nl;


let sig = "c:ylmd";
write nl;
write @text.(sig)( d1 ), @text.(sig)( d2 ), @text.(sig)( d3 ) nl;
write @text.(sig)( m1 ), @text.(sig)( m2 ), @text.(sig)( m3 ) nl;
write @text.(sig)( md ) nl;
write @text.(sig)( y ) nl;

write @date.(sig)("4662 Month 6 15"), @date.(sig)("4662 Leap 6 15"), @date.(sig)("4662 Month 7 15") nl;
write @date.(sig)("4662 Month 6"), @date.(sig)("4662 Leap 6"), @date.(sig)("4662 Month 7") nl;
write @date.(sig)("4662 6"), @date.(sig)("4662 7") nl;
write @date.(sig)("4662") nl;




